{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"endOfLine": "lf",
	"ignorePatterns": ["dist", "node_modules", ".astro", ".wrangler", ".tmp", ".clawpatch", ".git", "public/boot.js"],
	"insertFinalNewline": true,
	"printWidth": 200,
	"proseWrap": "preserve",
	"quoteProps": "as-needed",
	"semi": true,
	"singleQuote": false,
	"sortImports": true,
	"sortPackageJson": false,
	"tabWidth": 4,
	"trailingComma": "all",
	"useTabs": true
}
