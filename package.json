{
	"name": "tmp",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git@github.com:u29dc/tmp.git"
	},
	"scripts": {
		"commitlint": "bunx commitlint --edit",
		"prepare": "husky",
		"predev": "bun scripts/boot.ts",
		"dev": "bunx astro dev --background",
		"prebuild": "bun scripts/boot.ts",
		"build": "bunx astro build",
		"postbuild": "bun scripts/minify.ts",
		"preview": "bunx astro preview",
		"cf:deploy": "bun run util:check && bunx wrangler deploy",
		"cf:deploy:dry": "bun run build && bunx wrangler deploy --dry-run",
		"cf:dev": "bun run build && bunx wrangler dev",
		"cf:types": "bunx wrangler types wrangler.d.ts --include-runtime false",
		"util:clean": "rm -rf .astro dist node_modules/.vite .wrangler *.tsbuildinfo public/boot.js",
		"util:format": "bunx oxfmt --write .",
		"util:lint": "bunx oxlint . --type-aware --fix --deny-warnings",
		"util:types": "bunx astro check && bunx tsgo --noEmit --project tsconfig.scripts.json && bunx tsgo --noEmit --project tsconfig.cloudflare.json && bunx wrangler types wrangler.d.ts --include-runtime false --check",
		"util:check": "bun run util:format && bun run util:lint && bun run util:types && bun run build"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^14.1.2",
		"@astrojs/mdx": "^7.0.2",
		"@cloudflare/workers-types": "^5.20260712.1",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@minify-html/node": "^0.18.1",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@typescript/native-preview": "^7.0.0-dev.20260707.2",
		"astro": "^7.0.7",
		"cfg": "https://github.com/u29dc/cfg/releases/download/v1.0.7/cfg-1.0.7.tgz",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"rolldown": "^1.1.5",
		"tailwindcss": "^4.3.2",
		"typescript": "6.0.3",
		"wrangler": "^4.110.0"
	}
}
