{
	"name": "www",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git@github.com:u29dc/tmp.git"
	},
	"scripts": {
		"prepare": "husky",
		"dev": "bunx astro dev",
		"build": "bun run astro:build && bun run util:minify",
		"preview": "bunx astro preview",
		"update": "bun update --latest && bun add --dev astro@alpha @astrojs/cloudflare@alpha @astrojs/mdx@alpha && bun install",
		"astro:build": "bunx astro build",
		"astro:check": "bunx astro check",
		"commitlint": "bunx commitlint --edit",
		"util:clean": "rm -rf .astro dist node_modules/.vite *.tsbuildinfo",
		"util:format": "bunx oxfmt . --write --no-error-on-unmatched-pattern && bunx oxfmt . --check --no-error-on-unmatched-pattern",
		"util:lint": "bunx oxlint src scripts astro.config.ts commitlint.config.js lint-staged.config.js --fix --deny-warnings --no-error-on-unmatched-pattern",
		"util:minify": "bun scripts/minify.ts",
		"util:types": "bun run astro:check",
		"util:check": "bun run util:format && bun run util:lint && bun run util:types && bun run build"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^14.0.0-alpha.1",
		"@astrojs/mdx": "^6.0.0-alpha.1",
		"@commitlint/cli": "^21.1.0",
		"@commitlint/config-conventional": "^21.1.0",
		"@minify-html/node": "^0.18.1",
		"@tailwindcss/vite": "^4.3.1",
		"@tweakpane/core": "^2.0.5",
		"@types/node": "^26.0.0",
		"astro": "^7.0.0-alpha.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"rolldown": "^1.1.2",
		"tailwindcss": "^4.3.1",
		"tweakpane": "^4.0.5",
		"typescript": "^6.0.3"
	}
}
