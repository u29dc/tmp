{
	"name": "tmp",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git@github.com:u29dc/tmp.git"
	},
	"scripts": {
		"commitlint": "bunx commitlint --edit",
		"prepare": "husky",
		"dev": "bunx astro dev --background",
		"build": "bun run astro:build && bun run util:minify",
		"preview": "bunx astro preview",
		"deploy": "bun run util:check && bunx wrangler deploy",
		"deploy:dry": "bun run build && bunx wrangler deploy --dry-run",
		"cf:dev": "bun run build && bunx wrangler dev",
		"cf:types": "bunx wrangler types wrangler.d.ts --include-runtime false",
		"cf:types:check": "bunx wrangler types wrangler.d.ts --include-runtime false --check",
		"astro:build": "bunx astro build",
		"astro:check": "bunx astro check",
		"util:clean": "rm -rf .astro dist node_modules/.vite .wrangler *.tsbuildinfo",
		"util:format": "bunx oxfmt --write .",
		"util:format:check": "bunx oxfmt --check .",
		"util:lint": "bunx oxlint . --type-aware --deny-warnings",
		"util:minify": "bun scripts/minify.ts",
		"util:types": "bun run astro:check && bunx tsgo --noEmit --project tsconfig.scripts.json && bunx tsgo --noEmit --project tsconfig.cloudflare.json && bun run cf:types:check",
		"util:check": "STATUS=0; bun run util:format:check || STATUS=1; bun run util:lint || STATUS=1; bun run util:types || STATUS=1; bun run build || STATUS=1; exit $STATUS"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^14.1.1",
		"@astrojs/mdx": "^7.0.2",
		"@cloudflare/workers-types": "^5.20260707.1",
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@minify-html/node": "^0.18.1",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.0",
		"@typescript/native-preview": "^7.0.0-dev.20260707.2",
		"astro": "^7.0.6",
		"cfg": "https://github.com/u29dc/cfg/releases/download/v1.0.7/cfg-1.0.7.tgz",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"rolldown": "^1.1.4",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"wrangler": "^4.108.0"
	}
}
