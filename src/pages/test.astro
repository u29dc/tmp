---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Test" noindex>
	<main id="main" class="page-root test-page">
		<section class="test-page__panel" data-scroll data-scroll-call="test:panel">
			<a href="#test-target" data-ui="link">Jump to target</a>
			<button type="button" data-ui="button">Button state</button>
		</section>
		<section class="test-page__spacer" aria-hidden="true"></section>
		<section
			id="test-target"
			class="test-page__panel"
			data-scroll
			data-scroll-speed="0.08"
			tabindex="-1"
		>
			<a href="/" data-ui="link">Home route</a>
			<button type="button" data-ui="button" disabled>Disabled state</button>
		</section>
	</main>
</BaseLayout>

<style>
	.test-page {
		display: grid;
		gap: var(--space-16);
		padding: var(--space-16);
	}

	.test-page__panel {
		display: flex;
		min-block-size: 50dvh;
		align-items: center;
		justify-content: center;
		gap: var(--space-4);
		border: 1px solid var(--color-line);
	}

	.test-page__spacer {
		min-block-size: 80dvh;
	}
</style>
