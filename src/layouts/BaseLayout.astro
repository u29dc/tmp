---
import '@/styles/app.css';
import { SITE } from '@/data/site';
import { absoluteUrl } from '@/lib/seo';
import Router from '@/app/systems/router.astro';

type Props = {
	title?: string;
	description?: string;
	canonicalPath?: string;
	ogType?: 'website' | 'article';
	noindex?: boolean;
	mainClass?: string;
	publishedTime?: Date;
	modifiedTime?: Date;
	image?: {
		path?: string;
		type?: string;
		width?: number;
		height?: number;
		alt?: string;
	};
};

const {
	title = SITE.title,
	description = SITE.description,
	canonicalPath,
	ogType = 'website',
	noindex = false,
	mainClass,
	publishedTime,
	modifiedTime,
	image: pageImage,
} = Astro.props;
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.name}`;
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname);
const image = { ...SITE.ogImage, ...pageImage };
const ogImageUrl = absoluteUrl(image.path);
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang={SITE.lang} data-runtime="pending">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="color-scheme" content="light dark" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		{SITE.creator && <meta name="author" content={SITE.creator} />}
		{SITE.creator && <meta name="creator" content={SITE.creator} />}
		<meta name="application-name" content={SITE.name} />
		<meta name="keywords" content={SITE.keywords.join(', ')} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={SITE.themeColorLight} media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content={SITE.themeColorDark} media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" type="application/rss+xml" href={SITE.feeds.rss} title={`${SITE.name} RSS`} />
		<link rel="alternate" type="application/feed+json" href={SITE.feeds.json} title={`${SITE.name} JSON Feed`} />
		<link rel="alternate" type="text/plain" href={SITE.feeds.llms} title={`${SITE.name} LLMS context`} />
		<link rel="preload" href="/fonts/geist/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
		<link rel="manifest" href="/manifest.json" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="icon" href={SITE.faviconIcoPath} sizes="any" />
		<link rel="icon" href="/icon-32.png" sizes="32x32" type="image/png" />
		<link rel="apple-touch-icon" href={SITE.appleTouchIconPath} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:locale" content={SITE.locale} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:type" content={image.type} />
		<meta property="og:image:width" content={String(image.width)} />
		<meta property="og:image:height" content={String(image.height)} />
		<meta property="og:image:alt" content={image.alt} />
		{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={image.alt} />
		<Router />
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<main id="main" class:list={['min-h-dvh w-full p-(--space-page)', mainClass]}>
			<slot />
		</main>
		<script>
			import '@/app/app';
		</script>
	</body>
</html>
